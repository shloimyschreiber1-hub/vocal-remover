# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key (server-only secret, NEVER expose to the browser).
# Used by API routes to bypass RLS for storage + DB writes.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LALAL.AI
LALAL_API_KEY=your-lalal-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Configuration (for Contact Form)
# For Gmail, use: smtp.gmail.com with port 587
# For other providers, check their SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
CONTACT_EMAIL=contact@yourdomain.com
