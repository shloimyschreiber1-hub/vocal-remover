# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key (server-only secret, NEVER expose to the browser).
# Used by API routes to bypass RLS for storage + DB writes.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LALAL.AI
LALAL_API_KEY=your-lalal-api-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Configuration (for Contact Form)
# Using SendGrid for reliable email delivery
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=your-verified-sender@yourdomain.com
CONTACT_EMAIL=contact@yourdomain.com
